import axios from "axios";
import FormData from "form-data";

export default async function handler(req, res) {
  res.setHeader("Access-Control-Allow-Origin", "*");
  res.setHeader("Access-Control-Allow-Methods", "POST");
  res.setHeader("Access-Control-Allow-Headers", "Content-Type");

  if (req.method !== "POST") return res.status(405).json({ error: "POST only" });

  try {
    const { image } = req.body;
    if (!image) return res.status(400).json({ error: "Hakuna picha iliyopatikana" });

    const form = new FormData();
    form.append("api_user", process.env.SIGHTENGINE_USER || "");
    form.append("api_secret", process.env.SIGHTENGINE_SECRET || "");
    form.append("models", "nudity-2.1,weapon-1.0,gore-2.0");

    const base64Data = image.replace(/^data:image\/\w+;base64,/, "");
    const buffer = Buffer.from(base64Data, 'base64');
    form.append("media", buffer, { filename: 'upload.jpg' });

    try {
      const response = await axios.post("https://api.sightengine.com/1.0/check.json", form, {
        headers: form.getHeaders()
      });
      return res.status(200).json({ success: true, ai: response.data });
    } catch (apiErr) {
      // HAPA TUNARUDISHA KOSA HALISI KUTOKA SIGHTENGINE
      const errorMsg = apiErr.response?.data?.error || apiErr.message;
      return res.status(500).json({ error: "Sightengine Error: " + errorMsg });
    }
  } catch (err) {
    return res.status(500).json({ error: "System Error: " + err.message });
  }
}
